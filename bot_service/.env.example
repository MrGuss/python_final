APP_NAME=bot-service
ENV=local

TELEGRAM_BOT_TOKEN=your_tg_token

JWT_SECRET=change_me_super_secret
JWT_ALG=HS256

REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq//


OPENROUTER_API_KEY=your_openrouter_token
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nex-agi/nex-n2-pro:free
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=llm-fastapi-openrouter

# optional proxy for tg
# HTTP_PROXY=http://host.docker.internal:1082

# NO_PROXY=localhost,127.0.0.1,redis,rabbitmq,::1
